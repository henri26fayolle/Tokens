# Copy to .env for local dev (see README quickstart)
# Docker-free dev: DATABASE_URL=pglite://.data/dev (single process — pair with DEV_EMBED_GATEWAY=1)
DATABASE_URL=postgres://kaiden:kaiden@localhost:5433/kaiden

# Dev only: mount the gateway inside the api process (required for pglite)
# DEV_EMBED_GATEWAY=1

# Web push (production; dev auto-generates a throwaway pair)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:hello@kaiden.social

# Shown in the web app's setup snippets (default http://localhost:4000 in dev embed mode)
# NEXT_PUBLIC_GATEWAY_URL=https://gw.kaiden.social
# Web → api rewrite target (Vercel env once the api is hosted)
# API_ORIGIN=https://api.kaiden.social
API_PORT=4000
GATEWAY_PORT=4100

# Auth (apps/api). Required in production; a dev default is used otherwise.
# BETTER_AUTH_SECRET=generate-a-long-random-string
# API_URL=http://localhost:4000
# GitHub OAuth switches on when both are present:
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# XP sweep cadence in the api (0 disables; default 60000)
# XP_PROCESS_INTERVAL_MS=60000

# Gateway dev mode without a database: any single key that maps to a fake user.
# Events are logged (metadata only), not persisted. Normal mode needs DATABASE_URL
# plus a key minted via `pnpm --filter @kaiden/db seed:dev`.
# KAIDEN_DEV_KEY=kd_dev_local

# Upstream overrides (tests point these at a mock; production uses the defaults)
# ANTHROPIC_UPSTREAM=https://api.anthropic.com
# OPENAI_UPSTREAM=https://api.openai.com
