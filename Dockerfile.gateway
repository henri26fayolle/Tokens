# Kaiden gateway — Railway builds this via RAILWAY_DOCKERFILE_PATH=Dockerfile.gateway
# The gateway sits in users' critical path: keep this image boring and always-on.
FROM node:24-slim
WORKDIR /app
ENV COREPACK_ENABLE_DOWNLOAD_PROMPT=0
RUN corepack enable
COPY . .
RUN pnpm install --frozen-lockfile
ENV NODE_ENV=production
EXPOSE 4100
CMD ["pnpm", "--filter", "@kaiden/gateway", "start"]
