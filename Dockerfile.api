# Kaiden api — Railway builds this via RAILWAY_DOCKERFILE_PATH=Dockerfile.api
FROM node:24-slim
WORKDIR /app
ENV COREPACK_ENABLE_DOWNLOAD_PROMPT=0
RUN corepack enable
COPY . .
RUN pnpm install --frozen-lockfile
ENV NODE_ENV=production
EXPOSE 4000
# Migrations run before boot: idempotent, and a failed migration blocks the deploy.
CMD ["sh", "-c", "pnpm --filter @kaiden/db migrate:deploy && pnpm --filter @kaiden/api start"]
